{
    "name": "lukasbableck/contao-better-elementgroups-bundle",
    "type": "contao-bundle",
	"description": "This bundle improves how element groups and their children are displayed in the backend.",
	"keywords": [
		"backend",
		"element group",
		"nested element",
		"content"
	],
    "license": "LGPL-3.0-or-later",
	"authors": [
		{
			"name": "Lukas Bableck",
			"email": "lukas@bableck.dev",
			"homepage": "https://bableck.dev"
		}
	],
    "require": {
        "php": "^8.3",
        "contao/core-bundle": "^5.7",
        "symfony/dependency-injection": "^7.4",
        "symfony/deprecation-contracts": "^3.0",
        "symfony/event-dispatcher": "^7.4",
        "symfony/http-kernel": "^7.4",
        "symfony/security-bundle": "^7.4",
        "symfony/translation-contracts": "^3.0",
        "twig/twig": "^3.21"
    },
	"conflict": {
		"contao/manager-plugin": "<2.0 || >=3.0"
	},
	"require-dev": {
		"contao/manager-plugin": "^2.0",
		"friendsofphp/php-cs-fixer": "^3.57"
	},
    "autoload": {
        "psr-4": {
            "Lukasbableck\\ContaoBetterElementgroupsBundle\\": "src/"
        }
    },
	"extra": {
		"contao-manager-plugin": "Lukasbableck\\ContaoBetterElementgroupsBundle\\ContaoManager\\Plugin"
	}
}
